{
  "_comment": "High-performance client configuration with reliability and FEC",

  "mode": "client",

  "transport": {
    "type": "icmp",
    "icmp_mode": "echo",
    "protocol_number": 0,
    "_type_options": ["udp", "icmp", "raw"],
    "_protocol_number_comment": "Only used when type is 'raw'. Examples: 41=IPv6, 47=GRE, 50=ESP"
  },

  "listen": {
    "address": "127.0.0.1",
    "port": 1080
  },

  "server": {
    "address": "SERVER_IP_HERE",
    "port": 8080
  },

  "spoof": {
    "source_ip": "YOUR_SPOOF_SOURCE_IP",
    "source_ipv6": "",
    "peer_spoof_ip": "EXPECTED_SERVER_SPOOF_IP",
    "peer_spoof_ipv6": ""
  },

  "crypto": {
    "private_key": "YOUR_PRIVATE_KEY_BASE64",
    "peer_public_key": "SERVER_PUBLIC_KEY_BASE64"
  },

  "performance": {
    "buffer_size": 131072,
    "mtu": 1400,
    "session_timeout": 600,
    "workers": 8,
    "read_buffer": 8388608,
    "write_buffer": 8388608
  },

  "reliability": {
    "enabled": true,
    "window_size": 128,
    "retransmit_timeout_ms": 300,
    "max_retries": 5,
    "ack_interval_ms": 50
  },

  "fec": {
    "enabled": true,
    "data_shards": 10,
    "parity_shards": 3,
    "_comment": "FEC using Reed-Solomon. Can recover up to parity_shards lost packets per group. Overhead: parity/data ratio (here 30%)"
  },

  "keepalive": {
    "enabled": true,
    "interval_seconds": 30,
    "timeout_seconds": 120
  },

  "logging": {
    "level": "info",
    "file": ""
  }
}
